PORT=3000
BASE_URL=http://localhost:3000

# Storage: json for local dev, postgres for production.
STORE_DRIVER=json
# For PostgreSQL production traffic, row uses row-level order/payment writes.
# Set to document only for compatibility debugging.
POSTGRES_WRITE_MODE=row
DATABASE_URL=
DATABASE_POOL_MAX=10
REDIS_URL=
REDIS_KEY_PREFIX=kaito-ai-shop

# Dashboard admin bootstrap. Change these before real use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Required in production. Used to sign dashboard session cookies.
AUTH_SECRET=replace-with-a-long-random-secret

# Optional Telegram bot settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING=false
TELEGRAM_WEBHOOK_SECRET=
# Optional GIF/MP4 URL shown on /start. Leave blank to send text only.
TELEGRAM_WELCOME_ANIMATION_URL=
# Optional PNG shown above the /start caption.
TELEGRAM_START_IMAGE_FILE=public/brand/start/welcome.png
# Public support/admin handle shown in customer Telegram messages.
TELEGRAM_SUPPORT_HANDLE=@kaitoukit
# Optional sticker file_ids sent before sales flow messages.
TELEGRAM_START_STICKER_ID=
TELEGRAM_CATALOG_STICKER_ID=
TELEGRAM_BRAND_STICKER_ID=
TELEGRAM_TOPUP_STICKER_ID=
TELEGRAM_ACCOUNT_STICKER_ID=
TELEGRAM_LANGUAGE_STICKER_ID=
TELEGRAM_SUPPORT_STICKER_ID=
TELEGRAM_ORDER_STICKER_ID=
TELEGRAM_DELIVERY_STICKER_ID=
# Custom emoji pack automation. Owner id is your personal Telegram user id.
TELEGRAM_OWNER_USER_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CUSTOM_EMOJI_PACK_NAME=
TELEGRAM_CUSTOM_EMOJI_PACK_TITLE=KAITO AI SHOP Brands
TELEGRAM_CUSTOM_EMOJI_FORMAT=video
TELEGRAM_CUSTOM_TEXT_EMOJI=true
TELEGRAM_CUSTOM_EMOJI_MAP_FILE=data/telegram-custom-emoji-map.json
TELEGRAM_UI_EMOJI_MAP_FILE=data/telegram-ui-emoji-map.json
TELEGRAM_SLOGAN_EMOJI_MAP_FILE=data/telegram-slogan-emoji-map.json
TELEGRAM_BANNER_EMOJI_MAP_FILE=data/telegram-banner-emoji-map.json
TELEGRAM_EMOJI_REQUIRED_PACKS=banner,ui,slogan
TELEGRAM_EMOJI_HEALTH_REPORT_FILE=data/telegram-emoji-health-report.json
TELEGRAM_EMOJI_RELEASE_REPORT_FILE=data/telegram-emoji-release-report.json
TELEGRAM_ROBO_EMOJI_PACK_NAME=RoboEmoji
TELEGRAM_ROBO_EMOJI_MAP_FILE=data/telegram-robo-emoji-map.json
TELEGRAM_STICKER_MAP_FILE=data/telegram-shop-sticker-map.json

# Payment provider: mock or sepay.
PAYMENT_PROVIDER=mock

# Mock provider secret for payment webhooks.
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret

# Order safety controls.
ORDER_TTL_MINUTES=15
MAX_ORDER_QUANTITY=20
MAX_PENDING_ORDERS_PER_USER=3

# Traffic controls.
MAX_BODY_BYTES=1048576
RATE_LIMIT_AUTH_PER_MINUTE=12
RATE_LIMIT_PUBLIC_PER_MINUTE=600
RATE_LIMIT_ADMIN_PER_MINUTE=300
RATE_LIMIT_TELEGRAM_USER_PER_MINUTE=30
RATE_LIMIT_TELEGRAM_BUY_PER_MINUTE=6

# SePay QR settings. Set PAYMENT_PROVIDER=sepay to use these.
SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_CODE=
SEPAY_QR_TEMPLATE=compact
SEPAY_PAYMENT_PREFIX=KAITO
SEPAY_MEMO_PREFIX=
SEPAY_MEMO_SUFFIX=thanh toan don hang

# SePay webhook security: hmac, api_key, or none.
SEPAY_WEBHOOK_AUTH=hmac
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
