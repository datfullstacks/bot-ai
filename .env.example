PORT=3000
BASE_URL=http://localhost:3000

# Storage: json for local dev, postgres for production.
STORE_DRIVER=json
# For PostgreSQL production traffic, row uses row-level order/payment writes.
# Set to document only for compatibility debugging.
POSTGRES_WRITE_MODE=row
DATABASE_URL=
DATABASE_POOL_MAX=10
REDIS_URL=
REDIS_KEY_PREFIX=kaito-ai-shop

# Keep production sales closed until SePay, inventory policies and encrypted stock are ready.
SALES_ENABLED=false
# Optional Telegram user IDs allowed to run controlled purchases while public sales are closed.
SALES_TEST_TELEGRAM_IDS=
# 32-byte AES key encoded as 64 hexadecimal characters.
INVENTORY_ENCRYPTION_KEY=

# Dashboard admin bootstrap. Change these before real use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Required in production. Used to sign dashboard session cookies.
AUTH_SECRET=replace-with-a-long-random-secret

# Optional Telegram bot settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING=false
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
# Optional GIF/MP4 URL shown on /start. Leave blank to send text only.
TELEGRAM_WELCOME_ANIMATION_URL=
# Fastest /start image source: a Telegram photo file_id returned by sendPhoto.
TELEGRAM_START_IMAGE_FILE_ID=
# Optional public HTTPS image URL. When blank, an HTTPS BASE_URL is used for files under public/.
TELEGRAM_START_IMAGE_URL=
# Local PNG fallback. A successful upload is cached as a Telegram file_id until restart.
TELEGRAM_START_IMAGE_FILE=public/brand/start/welcome.png
# Public support/admin handle shown in customer Telegram messages.
TELEGRAM_SUPPORT_HANDLE=@kaitoukit
# Reserved legacy sticker file_ids. The current runtime does not send these automatically.
TELEGRAM_START_STICKER_ID=
TELEGRAM_CATALOG_STICKER_ID=
TELEGRAM_BRAND_STICKER_ID=
TELEGRAM_TOPUP_STICKER_ID=
TELEGRAM_ACCOUNT_STICKER_ID=
TELEGRAM_LANGUAGE_STICKER_ID=
TELEGRAM_SUPPORT_STICKER_ID=
TELEGRAM_ORDER_STICKER_ID=
TELEGRAM_DELIVERY_STICKER_ID=
# Custom emoji pack automation. Owner id is your personal Telegram user id.
TELEGRAM_OWNER_USER_ID=
TELEGRAM_CUSTOM_EMOJI_PACK_NAME=
TELEGRAM_CUSTOM_EMOJI_PACK_TITLE=KAITO AI SHOP Brands
TELEGRAM_CUSTOM_EMOJI_FORMAT=video
TELEGRAM_CUSTOM_TEXT_EMOJI=true
# Avoid repeated slow retries when Telegram temporarily rejects all custom emoji.
TELEGRAM_CUSTOM_EMOJI_CAPABILITY_COOLDOWN_MS=60000
TELEGRAM_CUSTOM_EMOJI_MAP_FILE=data/telegram-custom-emoji-map.json
TELEGRAM_UI_EMOJI_MAP_FILE=data/telegram-ui-emoji-map.json
TELEGRAM_SLOGAN_EMOJI_MAP_FILE=data/telegram-slogan-emoji-map.json
TELEGRAM_SLOGAN_TILE_EMOJI_MAP_FILE=data/telegram-slogan-tile-emoji-map.json
TELEGRAM_BANNER_EMOJI_MAP_FILE=data/telegram-banner-emoji-map.json
TELEGRAM_NEWS_EMOJI_MAP_FILE=data/telegram-news-emoji-map.json
TELEGRAM_FLAME_EMOJI_MAP_FILE=data/telegram-flame-emoji-map.json
TELEGRAM_GAME_EMOJI_MAP_FILE=data/telegram-game-emoji-map.json
TELEGRAM_ROBO_EMOJI_MAP_FILE=data/telegram-robo-emoji-map.json
TELEGRAM_RETRO_FONT_EMOJI_MAP_FILE=data/telegram-retro-font-emoji-map.json
# Runtime packs are always required. Retired banner/slogan values are ignored when normalizing legacy configs.
TELEGRAM_EMOJI_REQUIRED_PACKS=brand,ui,sloganTile,news,flame,game,robo,retro
TELEGRAM_EMOJI_HEALTH_REPORT_FILE=data/telegram-emoji-health-report.json
# When custom emoji is enabled, a configured bot token requires a successful report no older than this value.
TELEGRAM_EMOJI_HEALTH_MAX_AGE_HOURS=24
TELEGRAM_EMOJI_RELEASE_REPORT_FILE=data/telegram-emoji-release-report.json
TELEGRAM_ROBO_EMOJI_PACK_NAME=RoboEmoji
TELEGRAM_STICKER_MAP_FILE=data/telegram-shop-sticker-map.json

# Payment provider: mock or sepay.
PAYMENT_PROVIDER=mock

# Mock provider secret for payment webhooks.
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret

# Order safety controls.
ORDER_TTL_MINUTES=15
MAX_ORDER_QUANTITY=20
MAX_PENDING_ORDERS_PER_USER=3

# Automatic Seat fulfillment. The bot calls API services only; never call the
# Canva worker directly. Railway private-network examples are shown below.
MEMBER_FULFILLMENT_SWEEP_MS=30000
MEMBER_FULFILLMENT_CONCURRENCY=2
MEMBER_FULFILLMENT_RETRY_BASE_MS=30000
MEMBER_FULFILLMENT_MAX_RETRIES=8

GPT_MEMBER_SERVICE_ENABLED=false
# Railway (set PORT=3002 on gpt-member-service):
# http://${{gpt-member-service.RAILWAY_PRIVATE_DOMAIN}}:${{gpt-member-service.PORT}}/api/v1
GPT_MEMBER_SERVICE_URL=
# Seat fulfillment key: members:add only.
GPT_MEMBER_SERVICE_API_KEY=
# Dedicated Seat Guard key: accounts:read,members:remove. Falls back to the
# fulfillment key when blank. Keep accounts:write off unless this bot owns the
# complete upstream allowedMembers policy.
GPT_SEAT_GUARD_API_KEY=
# Mongo account id, ChatGPT workspace UUID, or admin email for the one target account.
GPT_MEMBER_ACCOUNT_REF=
GPT_MEMBER_SKUS=chatgpt-business-seat-1m
# Comma-separated owner/staff emails that Seat Guard must never offer to remove.
GPT_SEAT_PROTECTED_EMAILS=
# Fallback only for legacy Seat products/orders without seatTermMonths.
GPT_SEAT_DEFAULT_TERM_MONTHS=1
# Live member lists can approach 999 entries; keep a bounded response ceiling.
GPT_SEAT_GUARD_MAX_RESPONSE_BYTES=2097152
# Destructive expiry worker. Keep false until Seat Guard classifications have
# been reviewed; requires PostgreSQL row mode, members:remove permission, and
# DATABASE_POOL_MAX >= (2 * MEMBER_FULFILLMENT_CONCURRENCY) + 2 (default: 6).
GPT_SEAT_EXPIRY_AUTO_REMOVE=false
GPT_SEAT_EXPIRY_SWEEP_MS=900000
GPT_SEAT_EXPIRY_BATCH_SIZE=10
GPT_SEAT_EXPIRY_GRACE_MS=0
GPT_SEAT_EXPIRY_RETRY_WINDOW_MS=900000
GPT_MEMBER_REQUEST_TIMEOUT_MS=10000
GPT_MEMBER_OPERATION_TIMEOUT_MS=180000
GPT_MEMBER_POLL_INTERVAL_MS=1500

CANVA_MEMBER_SERVICE_ENABLED=false
# Railway (set PORT=3012 on canva-member-api):
# http://${{canva-member-api.RAILWAY_PRIVATE_DOMAIN}}:${{canva-member-api.PORT}}/api/v1
CANVA_MEMBER_SERVICE_URL=
CANVA_MEMBER_SERVICE_API_KEY=
# Dedicated Seat Guard key: accounts:read,members:remove. Falls back to the fulfillment key.
CANVA_SEAT_GUARD_API_KEY=
# Canva account id, login email, or configured account reference.
CANVA_MEMBER_ACCOUNT_REF=
CANVA_MEMBER_SKUS=canva-pro-1m,canva-pro-6m
CANVA_SEAT_PROTECTED_EMAILS=
CANVA_SEAT_DEFAULT_TERM_MONTHS=1
CANVA_SEAT_GUARD_MAX_RESPONSE_BYTES=2097152
CANVA_SEAT_EXPIRY_AUTO_REMOVE=false
CANVA_SEAT_EXPIRY_SWEEP_MS=900000
CANVA_SEAT_EXPIRY_BATCH_SIZE=10
CANVA_SEAT_EXPIRY_GRACE_MS=0
CANVA_SEAT_EXPIRY_RETRY_WINDOW_MS=900000
CANVA_MEMBER_REQUEST_TIMEOUT_MS=10000
CANVA_MEMBER_OPERATION_TIMEOUT_MS=600000
CANVA_MEMBER_POLL_INTERVAL_MS=2000

CLAUDE_MEMBER_SERVICE_ENABLED=false
# Railway (set PORT=3022 on claude-member-api):
# http://${{claude-member-api.RAILWAY_PRIVATE_DOMAIN}}:${{claude-member-api.PORT}}/api/v1
CLAUDE_MEMBER_SERVICE_URL=
CLAUDE_MEMBER_SERVICE_API_KEY=
# Dedicated Seat Guard key: accounts:read,members:remove. Falls back to the fulfillment key.
CLAUDE_SEAT_GUARD_API_KEY=
# Default Claude account id, organization UUID, login email, or configured account reference.
CLAUDE_MEMBER_ACCOUNT_REF=
# Optional JSON object mapping individual SKUs to different Claude account refs.
CLAUDE_MEMBER_ACCOUNT_REFS_BY_SKU={}
CLAUDE_MEMBER_SKUS=claude-business-seat-1x-1m,claude-business-seat-6-5x-1m
CLAUDE_SEAT_PROTECTED_EMAILS=
CLAUDE_SEAT_DEFAULT_TERM_MONTHS=1
CLAUDE_SEAT_GUARD_MAX_RESPONSE_BYTES=2097152
CLAUDE_SEAT_EXPIRY_AUTO_REMOVE=false
CLAUDE_SEAT_EXPIRY_SWEEP_MS=900000
CLAUDE_SEAT_EXPIRY_BATCH_SIZE=10
CLAUDE_SEAT_EXPIRY_GRACE_MS=0
CLAUDE_SEAT_EXPIRY_RETRY_WINDOW_MS=900000
CLAUDE_MEMBER_REQUEST_TIMEOUT_MS=10000
CLAUDE_MEMBER_OPERATION_TIMEOUT_MS=600000
CLAUDE_MEMBER_POLL_INTERVAL_MS=2000

# Traffic controls.
MAX_BODY_BYTES=1048576
RATE_LIMIT_AUTH_PER_MINUTE=12
RATE_LIMIT_PUBLIC_PER_MINUTE=600
RATE_LIMIT_ADMIN_PER_MINUTE=300
RATE_LIMIT_TELEGRAM_USER_PER_MINUTE=30
RATE_LIMIT_TELEGRAM_BUY_PER_MINUTE=6

# SePay QR settings. Set PAYMENT_PROVIDER=sepay to use these.
SEPAY_ACCOUNT_NUMBER=
SEPAY_BANK_CODE=
SEPAY_QR_TEMPLATE=compact
SEPAY_PAYMENT_PREFIX=KAITO
SEPAY_MEMO_PREFIX=
SEPAY_MEMO_SUFFIX=thanh toan don hang

# SePay webhook security: hmac, api_key, or none.
SEPAY_WEBHOOK_AUTH=hmac
SEPAY_WEBHOOK_SECRET=
SEPAY_WEBHOOK_API_KEY=
# Optional comma-separated allowlists checked against webhook payloads.
SEPAY_WEBHOOK_ACCOUNT_NUMBERS=
SEPAY_WEBHOOK_GATEWAYS=
