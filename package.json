{
  "name": "kaito-ai-shop",
  "version": "0.1.0",
  "description": "KAITO AI SHOP Telegram sales bot and admin dashboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "check": "node scripts/check-syntax.js",
    "test": "node scripts/smoke-test.js",
    "test:admin-ui": "node scripts/admin-ui-regression-test.js",
    "test:admin-dashboard-ui": "node scripts/admin-dashboard-ui-regression-test.js",
    "test:telegram": "node scripts/telegram-message-regression-test.js",
    "test:telegram-callback": "node scripts/telegram-callback-smoke-test.js",
    "test:sepay": "node scripts/sepay-auto-regression-test.js",
    "test:system": "node scripts/system-readiness-regression-test.js",
    "test:telegram-custom-emojis": "node scripts/telegram-custom-emoji-pack-test.js",
    "test:telegram-robo-emojis": "node scripts/telegram-robo-emoji-pack-test.js",
    "test:telegram-retro-font-emojis": "node scripts/telegram-retro-font-emoji-pack-test.js",
    "test:telegram-brand-motion": "node scripts/telegram-brand-motion-assets-test.js",
    "test:telegram-ui-motion": "node scripts/telegram-ui-motion-assets-test.js",
    "test:telegram-menu-motion": "node scripts/telegram-menu-motion-assets-test.js && python scripts/telegram-menu-motion-assets-py-test.py",
    "test:telegram-banner-emojis": "node scripts/telegram-banner-emoji-assets-test.js",
    "test:telegram-slogan-tiles": "node scripts/telegram-slogan-tile-assets-test.js && python scripts/telegram-slogan-tile-effects-test.py && python scripts/telegram-slogan-tile-visual-test.py",
    "test:telegram-emoji-health": "node scripts/telegram-emoji-registry-test.js && node scripts/telegram-emoji-health-test.js",
    "test:telegram-transport": "node scripts/telegram-transport-degrade-test.js",
    "test:telegram-slogan-motion": "node scripts/telegram-slogan-motion-assets-test.js",
    "test:telegram-shop-stickers": "node scripts/telegram-shop-sticker-assets-test.js && node scripts/telegram-shop-sticker-pack-test.js",
    "test:catalog": "node scripts/catalog-regression-test.js",
    "test:brand-icons": "node scripts/brand-assets-regression-test.js",
    "test:postgres": "node scripts/smoke-test.js --postgres",
    "preflight": "node scripts/preflight.js",
    "preflight:production": "node scripts/preflight.js --strict",
    "seed:catalog": "node scripts/seed-catalog.js",
    "telegram:create-custom-emojis": "node scripts/telegram-custom-emoji-pack.js",
    "telegram:probe-custom-emojis": "node scripts/telegram-custom-emoji-probe.js",
    "telegram:emoji-health": "node scripts/telegram-emoji-health.js",
    "telegram:release-emojis": "node scripts/telegram-emoji-release.js",
    "telegram:create-news-emojis": "node scripts/telegram-custom-emoji-pack.js --format animated --source public/brand/news-emoji --output data/telegram-news-emoji-map.json --base kaito_ai_shop_news_emoji --title \"KAITO AI SHOP News Emoji\"",
    "telegram:create-flame-emojis": "node scripts/telegram-custom-emoji-pack.js --format animated --source public/brand/flame-emoji --output data/telegram-flame-emoji-map.json --base kaito_ai_shop_flame_emoji --title \"KAITO AI SHOP Flame Emoji\"",
    "telegram:create-game-emojis": "node scripts/telegram-custom-emoji-pack.js --format animated --source public/brand/game-emoji --output data/telegram-game-emoji-map.json --base kaito_ai_shop_game_emoji --title \"KAITO AI SHOP Game Emoji\"",
    "telegram:import-robo-emojis": "node scripts/telegram-robo-emoji-pack.js",
    "telegram:import-retro-font-emojis": "node scripts/telegram-retro-font-emoji-pack.js",
    "telegram:generate-brand-motion": "node scripts/telegram-brand-motion-assets.js",
    "telegram:generate-ui-motion": "node scripts/telegram-ui-motion-assets.js",
    "telegram:generate-menu-motion": "node scripts/telegram-menu-motion-assets.js",
    "telegram:generate-banner-emojis": "node scripts/telegram-banner-emoji-assets.js",
    "telegram:generate-slogan-tiles": "node scripts/telegram-slogan-tile-assets.js",
    "telegram:generate-slogan-motion": "node scripts/telegram-slogan-motion-assets.js",
    "telegram:render-start-image": "python scripts/render-start-retro-image.py",
    "telegram:generate-shop-stickers": "node scripts/telegram-shop-sticker-assets.js",
    "telegram:create-shop-stickers": "node scripts/telegram-shop-sticker-pack.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "verify": "npm run check && npm test && npm run test:admin-ui && npm run test:admin-dashboard-ui && npm run test:telegram && npm run test:telegram-transport && npm run test:telegram-callback && npm run test:sepay && npm run test:system && npm run test:telegram-custom-emojis && npm run test:telegram-robo-emojis && npm run test:telegram-retro-font-emojis && npm run test:telegram-brand-motion && npm run test:telegram-ui-motion && npm run test:telegram-menu-motion && npm run test:telegram-banner-emojis && npm run test:telegram-slogan-tiles && npm run test:telegram-emoji-health && npm run test:telegram-slogan-motion && npm run test:telegram-shop-stickers && npm run test:catalog && npm run test:brand-icons",
    "migrate:postgres": "node src/migrateJsonToPostgres.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  }
}
